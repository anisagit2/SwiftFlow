{
  "name": "swiftflow-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "deploy": "gcloud run deploy swiftflow-backend --source . --region ${GOOGLE_CLOUD_REGION:-us-central1} --allow-unauthenticated --project ${GOOGLE_CLOUD_PROJECT:-YOUR_PROJECT_ID} --set-env-vars GOOGLE_CLOUD_PROJECT=${GOOGLE_CLOUD_PROJECT:-YOUR_PROJECT_ID},FIREBASE_PROJECT_ID=${FIREBASE_PROJECT_ID:-YOUR_FIREBASE_PROJECT_ID},VERTEX_AI_LOCATION=${VERTEX_AI_LOCATION:-us-central1},GEMINI_MODEL=${GEMINI_MODEL:-gemini-1.5-flash},TRANSLATION_ENABLED=${TRANSLATION_ENABLED:-true},TRANSLATION_FALLBACK_LANGUAGE=${TRANSLATION_FALLBACK_LANGUAGE:-en},BACKEND_BASE_URL=${BACKEND_BASE_URL:-},INTERNAL_TASK_SECRET=${INTERNAL_TASK_SECRET:-},CLOUD_TASKS_LOCATION=${CLOUD_TASKS_LOCATION:-us-central1},CLOUD_TASKS_QUEUE=${CLOUD_TASKS_QUEUE:-swiftflow-trip-tasks},TASK_INVOKER_SERVICE_ACCOUNT=${TASK_INVOKER_SERVICE_ACCOUNT:-},ALLOW_UNAUTHENTICATED_DEV=false,ALLOWED_ORIGINS=${ALLOWED_ORIGINS:-http://localhost:5173}"
  },
  "dependencies": {
    "@google-cloud/tasks": "^6.2.1",
    "@google-cloud/translate": "^9.3.0",
    "@google-cloud/vertexai": "^1.12.0",
    "firebase-admin": "^13.8.0"
  }
}
